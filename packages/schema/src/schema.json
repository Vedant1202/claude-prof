{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cprof.dev/schema/v1.json",
  "title": "Claude Profile",
  "description": "Phase 1 cprof manifest for local Claude Code profile snapshots.",
  "type": "object",
  "required": [
    "$schema",
    "name",
    "version",
    "profileScope",
    "includesGlobal",
    "sources"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://cprof.dev/schema/v1.json"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "claudeCode": {
      "type": "string"
    },
    "profileScope": {
      "enum": ["project", "global"]
    },
    "includesGlobal": {
      "type": "boolean"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source"
      }
    },
    "settings": {
      "$ref": "#/$defs/settings"
    },
    "memory": {
      "type": "object",
      "propertyNames": { "pattern": "^[A-Za-z0-9._-]+$" },
      "additionalProperties": {
        "$ref": "#/$defs/profileItem"
      }
    },
    "rules": {
      "type": "object",
      "propertyNames": { "pattern": "^[A-Za-z0-9._-]+$" },
      "additionalProperties": {
        "$ref": "#/$defs/profileItem"
      }
    },
    "plugins": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/plugin"
      }
    },
    "skills": {
      "type": "object",
      "propertyNames": { "pattern": "^[A-Za-z0-9._-]+$" },
      "additionalProperties": {
        "$ref": "#/$defs/profileItem"
      }
    },
    "commands": {
      "type": "object",
      "propertyNames": { "pattern": "^[A-Za-z0-9._-]+$" },
      "additionalProperties": {
        "$ref": "#/$defs/profileItem"
      }
    },
    "agents": {
      "type": "object",
      "propertyNames": { "pattern": "^[A-Za-z0-9._-]+$" },
      "additionalProperties": {
        "$ref": "#/$defs/profileItem"
      }
    },
    "hooks": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/hookInventory"
      }
    },
    "mcpServers": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/mcpServer"
      }
    },
    "secrets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "optional": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    }
  },
  "$defs": {
    "scope": {
      "enum": ["project", "global"]
    },
    "source": {
      "type": "object",
      "required": ["scope"],
      "additionalProperties": false,
      "properties": {
        "scope": {
          "$ref": "#/$defs/scope"
        },
        "root": {
          "type": "string"
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "private": {
          "type": "boolean"
        }
      }
    },
    "profileItem": {
      "type": "object",
      "required": ["source"],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string"
        },
        "hash": {
          "type": "string",
          "pattern": "^sha256:[a-fA-F0-9]{64}$"
        },
        "scope": {
          "$ref": "#/$defs/scope"
        },
        "private": {
          "type": "boolean"
        }
      }
    },
    "plugin": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "marketplace": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "scope": {
          "$ref": "#/$defs/scope"
        },
        "private": {
          "type": "boolean"
        }
      }
    },
    "hookInventory": {
      "type": "object",
      "required": ["event"],
      "additionalProperties": false,
      "properties": {
        "event": {
          "type": "string",
          "minLength": 1
        },
        "matcher": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "scope": {
          "$ref": "#/$defs/scope"
        },
        "private": {
          "type": "boolean"
        },
        "inventoryOnly": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "mcpServer": {
      "type": "object",
      "required": ["command"],
      "additionalProperties": true,
      "properties": {
        "command": {
          "type": "string"
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "scope": {
          "$ref": "#/$defs/scope"
        },
        "private": {
          "type": "boolean"
        }
      }
    },
    "settings": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "model": {
          "type": "string"
        },
        "permissions": {
          "type": "object",
          "additionalProperties": true
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    }
  }
}
